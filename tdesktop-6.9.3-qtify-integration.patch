+		-> rpl::producer<NavigationHistoryState> override;
+
+private:
+	void setupProfile(const Config &config);
+	void injectMessageBridge();
+	void updateBgColor();
+
+	base::unique_qptr<QWebEngineView> _view;
+	QWebEngineProfile *_profile = nullptr;
+	Page *_page = nullptr;
+	Handler *_handler = nullptr;
+
+	Config _config;
