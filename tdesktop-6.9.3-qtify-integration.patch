+[[nodiscard]] QString StoragePath(const std::string &token) {
+	if (token.empty()) {
+		return {};
+	}
+	return QStandardPaths::writableLocation(
+		QStandardPaths::CacheLocation) + '/' + kStoragePrefix + QString::fromStdString(token);
+}
