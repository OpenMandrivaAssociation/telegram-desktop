+class Handler final : public QWebEngineUrlSchemeHandler {
+public:
+	explicit Handler(Fn<DataResult(DataRequest)> handler);
+
+	void requestStarted(QWebEngineUrlRequestJob *job) override;
+
+private:
+	const Fn<DataResult(DataRequest)> _handler;
+};
+
+Handler::Handler(Fn<DataResult(DataRequest)> handler)
+: _handler(std::move(handler)) {
+}
+
+void Handler::requestStarted(QWebEngineUrlRequestJob *job) {
+	if (!_handler) {
+		job->fail(QWebEngineUrlRequestJob::UrlInvalid);
+		return;
+	}
+	auto request = DataRequest{
+		.id = job->requestUrl().path().mid(1).toStdString(),
+		.offset = 0,
+		.limit = -1,
+	};
+	const auto range = job->requestHeaders().value("Range");
+	if (!range.isEmpty()) {
+		ParseRangeHeaderFor(request, range.toStdString());
+	}
+	const auto result = _handler(request);
+	if (result == DataResult::Failed) {
+		job->fail(QWebEngineUrlRequestJob::UrlInvalid);
+		return;
+	}
+	if (result == DataResult::Pending) {
+		job->fail(QWebEngineUrlRequestJob::UrlInvalid);
+		return;
+	}
+	job->fail(QWebEngineUrlRequestJob::UrlInvalid);
+}
