+bool AutostartSkip() {
+	return false;
+}
+
+bool AutostartSupported() { return true; }
+bool SkipTaskbarSupported() { return true; }
+bool TrayIconSupported() { return true; }
+
+void AutostartToggle(bool enabled, Fn<void(bool)> done) {
+	if (KSandbox::isFlatpak()) {
+		const auto dir = QStandardPaths::writableLocation(
+			QStandardPaths::ConfigLocation) + "/autostart";
+		QDir().mkpath(dir);
+		const auto path = dir + "/org.telegram.desktop.desktop";
+		if (enabled) {
+			const auto executable = ExecutablePathForShortcuts();
+			if (executable.isEmpty()) {
+				if (done) done(false);
+				return;
+			}
+			auto file = QFile(path);
+			if (file.open(QIODevice::WriteOnly | QIODevice::Text)) {
+				QTextStream stream(&file);
+				stream << "[Desktop Entry]\n";
+				stream << "Type=Application\n";
+				stream << "Name=Telegram Desktop\n";
+				stream << "Exec=" << executable << " -- %u\n";
+				stream << "Icon=org.telegram.desktop\n";
+				stream << "Terminal=false\n";
+				stream << "StartupWMClass=TelegramDesktop\n";
+			}
+		} else {
+			QFile::remove(path);
+		}
+		if (done) done(true);
+		return;
+	}
+
+	const auto autostart = QStandardPaths::writableLocation(
+		QStandardPaths::GenericConfigLocation)
+		+ u"/autostart/"_q;
+	const auto desktop = QGuiApplication::desktopFileName() + u".desktop"_q;
+	const auto path = autostart + desktop;
+	if (!enabled) {
+		QFile::remove(path);
+		if (done) done(true);
+		return;
+	}
+	QDir().mkpath(autostart);
+	auto f = QFile(path);
+	if (f.open(QIODevice::WriteOnly | QIODevice::Text)) {
+		QTextStream s(&f);
+		s << "[Desktop Entry]\n";
+		s << "Type=Application\n";
+		s << "Name=Telegram Desktop\n";
+		s << "Exec=" << (cExeDir() + cExeName()) << " -autostart\n";
+		s << "Icon=org.telegram.desktop\n";
+		s << "Terminal=false\n";
+	}
+	if (done) done(QFile::exists(path));
+}
