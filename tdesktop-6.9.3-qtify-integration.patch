+struct SystemMediaControls::Private : QObject {
+	Private() {
+		_root = new QObject(this);
+		_rootAdaptor = new MprisRootAdaptor(_root);
+		_playerAdaptor = new MprisPlayerAdaptor(_root);
+
+		_playerAdaptor->setCommandHandler([=](Command cmd) {
+			_commandRequests.fire_copy(cmd);
+			if (cmd == Command::Raise) {
+				// already handled in adaptor too
+			}
+		});
+		_playerAdaptor->setSeekHandler([=](float64 progress) {
+			_seekRequests.fire_copy(progress);
+		});
+		_playerAdaptor->setVolumeHandler([=](float64 v) {
+			_volumeChangeRequests.fire_copy(v);
+		});
+		_playerAdaptor->setUpdatePositionHandler([=] {
+			_updatePositionRequests.fire({});
+		});
+	}
+
+	[[nodiscard]] rpl::producer<Command> commandRequests() const {
+		return _commandRequests.events();
+	}
+	[[nodiscard]] rpl::producer<float64> seekRequests() const {
+		return _seekRequests.events();
+	}
+	[[nodiscard]] rpl::producer<float64> volumeChangeRequests() const {
+		return _volumeChangeRequests.events();
+	}
+	[[nodiscard]] rpl::producer<> updatePositionRequests() const {
+		return _updatePositionRequests.events();
+	}
+
+	void setApplicationName(const QString &name) {
+		_appName = name;
+	}
+	bool init() {
+		auto connection = QDBusConnection::sessionBus();
+		if (!connection.isConnected()) {
+			return false;
+		}
+		const auto service = kMprisServicePrefix + u"telegramdesktop"_q;
+		if (!connection.registerService(service)) {
+			// Another instance may own it; still try to own the object.
+		}
+		if (!connection.registerObject(
+				kMprisPath,
+				_root,
+				QDBusConnection::ExportAdaptors)) {
+			return false;
+		}
+		_registered = true;
+		return true;
+	}
+
+	void setEnabled(bool enabled) {
+		_enabled = enabled;
+		updateAdaptors();
+	}
+	void setIsNextEnabled(bool value) { _canNext = value; updateAdaptors(); }
+	void setIsPreviousEnabled(bool value) { _canPrev = value; updateAdaptors(); }
+	void setIsPlayPauseEnabled(bool value) { _canPlayPause = value; updateAdaptors(); }
+	void setIsStopEnabled(bool value) { _canStop = value; updateAdaptors(); }
+
+	void setPlaybackStatus(PlaybackStatus status) {
+		_status = status;
+		updateAdaptors();
+	}
+	void setLoopStatus(LoopStatus status) {
+		_loop = status;
+		updateAdaptors();
+	}
+	void setShuffle(bool value) {
+		_shuffle = value;
+		updateAdaptors();
+	}
+
+	void setTitle(const QString &title) {
+		_title = title;
+		rebuildMetadata();
+	}
+	void setArtist(const QString &artist) {
+		_artist = artist;
+		rebuildMetadata();
+	}
+	void setThumbnail(const QImage &image) {
+		_thumbnail = image;
+		if (!_thumbnail.isNull()) {
+			_thumbnail.save(ArtTempPath(), "PNG");
+		} else {
+			QFile::remove(ArtTempPath());
+		}
+		rebuildMetadata();
+	}
+	void setDuration(int durationMs) {
+		_duration = durationMs;
+		rebuildMetadata();
+	}
+	void setPosition(int positionMs) {
+		_position = positionMs;
+		updateAdaptors();
+	}
+	void setVolume(float64 volume) {
+		_volume = volume;
+		updateAdaptors();
+	}
+
+	void clearThumbnail() {
+		_thumbnail = QImage();
+		QFile::remove(ArtTempPath());
+		rebuildMetadata();
+	}
+	void clearMetadata() {
+		_title = _artist = QString();
+		_thumbnail = QImage();
+		_duration = 0;
+		rebuildMetadata();
+	}
+	void updateDisplay() {
+		updateAdaptors();
+	}
+
+private:
+	void rebuildMetadata() {
+		QVariantMap map;
+		if (!_title.isEmpty()) {
+			map.insert(u"xesam:title"_q, _title);
+		}
+		if (!_artist.isEmpty()) {
+			map.insert(u"xesam:artist"_q, QStringList{ _artist });
+		}
+		if (_duration > 0) {
+			map.insert(u"mpris:length"_q, qlonglong(_duration) * 1000);
+		}
+		const auto art = ArtTempPath();
+		if (QFile::exists(art)) {
+			map.insert(u"mpris:artUrl"_q, QUrl::fromLocalFile(art).toString());
+		}
+		_metadata = map;
+		updateAdaptors();
+	}
+
+	void updateAdaptors() {
+		if (!_registered || !_playerAdaptor) return;
+
+		QVariantMap md = _metadata;
+		// always provide some identity
+		if (!md.contains(u"xesam:title"_q)) {
+			md.insert(u"xesam:title"_q, _appName.isEmpty() ? u"Telegram Desktop"_q : _appName);
+		}
+
+		_playerAdaptor->setInternalState(
+			_status,
+			_loop,
+			_shuffle,
+			md,
+			_volume,
+			_position,
+			_canNext && _enabled,
+			_canPrev && _enabled,
+			_canPlayPause && _enabled,
+			/*canSeek*/ true);
+
+		// Root properties rarely change.
+	}
+
+	QString _appName;
+	bool _registered = false;
+	bool _enabled = false;
+
+	PlaybackStatus _status = PlaybackStatus::Stopped;
+	LoopStatus _loop = LoopStatus::None;
+	bool _shuffle = false;
+	QString _title;
+	QString _artist;
+	QImage _thumbnail;
+	int _duration = 0;
+	int _position = 0;
+	double _volume = 1.;
+	bool _canNext = false;
+	bool _canPrev = false;
+	bool _canPlayPause = false;
+	bool _canStop = false;
+
+	QVariantMap _metadata;
+
+	rpl::event_stream<Command> _commandRequests;
+	rpl::event_stream<float64> _seekRequests;
+	rpl::event_stream<float64> _volumeChangeRequests;
+	rpl::event_stream<> _updatePositionRequests;
+
+	QObject *_root = nullptr;
+	MprisRootAdaptor *_rootAdaptor = nullptr;
+	MprisPlayerAdaptor *_playerAdaptor = nullptr;
+};
