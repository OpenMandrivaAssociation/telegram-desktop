+constexpr auto kMprisPath = "/org/mpris/MediaPlayer2";
+constexpr auto kMprisServicePrefix = "org.mpris.MediaPlayer2.";
+
+[[nodiscard]] QString MprisStatus(SystemMediaControls::PlaybackStatus status) {
+	switch (status) {
+	case SystemMediaControls::PlaybackStatus::Playing: return u"Playing"_q;
+	case SystemMediaControls::PlaybackStatus::Paused: return u"Paused"_q;
+	case SystemMediaControls::PlaybackStatus::Stopped: return u"Stopped"_q;
+	}
+	return u"Stopped"_q;
+}
+
+[[nodiscard]] QString MprisLoopStatus(SystemMediaControls::LoopStatus status) {
+	switch (status) {
+	case SystemMediaControls::LoopStatus::Track: return u"Track"_q;
+	case SystemMediaControls::LoopStatus::Playlist: return u"Playlist"_q;
+	case SystemMediaControls::LoopStatus::None:
+	default: return u"None"_q;
+	}
+}
+
+[[nodiscard]] QString ArtTempPath() {
+	return QDir::tempPath() + u"/tdesktop-mpris-art.png"_q;
+}
