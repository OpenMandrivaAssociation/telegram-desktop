+	rpl::event_stream<NavigationHistoryState> _navHistory;
+};
+
+[[nodiscard]] bool RegisterSchemes() {
+	static const bool done = [] {
+		auto data = QWebEngineUrlScheme(kDataScheme);
+		data.setSyntax(QWebEngineUrlScheme::Syntax::Path);
+		data.setFlags(
+			QWebEngineUrlScheme::SecureScheme
+			| QWebEngineUrlScheme::LocalScheme
+			| QWebEngineUrlScheme::LocalAccessAllowed
+			| QWebEngineUrlScheme::ContentSecurityPolicyIgnored);
+		QWebEngineUrlScheme::registerScheme(data);
+
+		auto msg = QWebEngineUrlScheme(kMessageScheme);
+		msg.setSyntax(QWebEngineUrlScheme::Syntax::Path);
+		msg.setFlags(QWebEngineUrlScheme::SecureScheme);
+		QWebEngineUrlScheme::registerScheme(msg);
+		return true;
+	}();
+	return done;
+}
+
+QtWebEngineInterface::QtWebEngineInterface(Config config)
+: _config(std::move(config)) {
+	RegisterSchemes();
+
+	_view = base::make_unique_q<QWebEngineView>(_config.parent);
+	_page = new Page(_view.get());
+	_view->setPage(_page);
+
+	setupProfile(_config);
+
+	_page->setMessageHandler([=](std::string text, bool /*main*/) {
+		if (_config.messageHandler) {
+			_config.messageHandler({ .text = std::move(text) });
+		}
+	});
+	_page->setNavigationStartHandler(_config.navigationStartHandler);
+	_page->setNavigationDoneHandler(_config.navigationDoneHandler);
+
+	if (_config.dataRequestHandler) {
+		_handler = new Handler(_config.dataRequestHandler);
+		_profile->installUrlSchemeHandler(kDataScheme, _handler);
+	}
+
+	auto settings = _page->settings();
+	settings->setAttribute(QWebEngineSettings::JavascriptEnabled, true);
+	settings->setAttribute(QWebEngineSettings::PluginsEnabled, false);
+	settings->setAttribute(QWebEngineSettings::FullScreenSupportEnabled, true);
+
+	_bg = _config.opaqueBg.isValid() ? _config.opaqueBg : Qt::white;
+	updateBgColor();
+
+	_view->setContextMenuPolicy(Qt::NoContextMenu);
+
+	injectMessageBridge();
+}
+
+QtWebEngineInterface::~QtWebEngineInterface() {
+	if (_handler && _profile) {
+		_profile->removeUrlSchemeHandler(_handler);
+	}
+}
+
+void QtWebEngineInterface::setupProfile(const Config &config) {
+	if (!config.userDataToken.empty()) {
+		const auto path = StoragePath(config.userDataToken);
+		if (!path.isEmpty()) {
+			_profile = new QWebEngineProfile(path, _view.get());
+			_profile->setPersistentCookiesPolicy(
+				QWebEngineProfile::AllowPersistentCookies);
+			_profile->setHttpCacheType(QWebEngineProfile::DiskHttpCache);
+			return;
+		}
+	}
+	_profile = QWebEngineProfile::defaultProfile();
+}
+
+void QtWebEngineInterface::injectMessageBridge() {
+	const auto scriptSource = uR"(
+(function() {
+if (window.TelegramDesktop && window.TelegramDesktop.__td_injected) return;
+window.TelegramDesktop = window.TelegramDesktop || {};
+window.TelegramDesktop.__td_injected = true;
+window.TelegramDesktop.postMessage = function(obj) {
+	try {
+		var s = (typeof obj === 'string') ? obj : JSON.stringify(obj);
+		if (s.length > )" + QString::number(kMaxMessageBytes) + uR"() s = s.substring(0, )" + QString::number(kMaxMessageBytes) + uR"();
+		location.href = ')" + kMessageScheme + uR"(:)" + kMessagePath + uR"(?data=' + encodeURIComponent(s);
+	} catch(e) {}
+};
+})();
+)"_q;
+
+	auto script = QWebEngineScript();
+	script.setSourceCode(scriptSource);
+	script.setInjectionPoint(QWebEngineScript::DocumentCreation);
+	script.setWorldId(QWebEngineScript::MainWorld);
+	_page->scripts().insert(script);
+}
+
+void QtWebEngineInterface::updateBgColor() {
+	if (_view) {
+		auto palette = _view->palette();
+		palette.setColor(QPalette::Base, _bg);
+		_view->setPalette(palette);
+	}
+}
+
+void QtWebEngineInterface::navigate(std::string url) {
+	_view->load(QUrl(QString::fromStdString(url)));
+}
