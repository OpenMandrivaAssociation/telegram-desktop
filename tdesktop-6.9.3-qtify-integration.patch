+QString ExecutablePathForShortcuts() {
+	const auto exeLink = QFileInfo(u"/proc/%1/exe"_q.arg(getpid()));
+	if (exeLink.exists() && exeLink.isSymLink()) {
+		return exeLink.canonicalFilePath();
+	}
+	// Fallback to the first command line argument or cExeDir + cExeName.
+	return (cExeDir() + cExeName());
+}
+
+void SetApplicationIcon(const QIcon &icon) {
+	QGuiApplication::setWindowIcon(icon);
+}
+
+QString SingleInstanceLocalServerName(const QString &name) {
+	return name + u"-singleinstance"_q;
+}
