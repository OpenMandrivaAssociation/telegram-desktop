-	return url.isValid()
-		&& url.scheme() == "https"
-		&& url.host() == "web.telegram.org"
-		&& url.port(443) == 443
-		&& url.userInfo().isEmpty()
-		&& url.path().isEmpty()
-		&& url.query().isEmpty()
-		&& url.fragment().isEmpty();
-}
