+class MprisRootAdaptor : public QDBusAbstractAdaptor {
+	Q_OBJECT
+public:
+	explicit MprisRootAdaptor(QObject *parent) : QDBusAbstractAdaptor(parent) {}
+
+public Q_SLOTS:
+	void Raise() {
+		Core::Sandbox::Instance().customEnterFromEventLoop([] {
+			Core::App().activate();
+		});
+	}
+	void Quit() {
+		QCoreApplication::quit();
+	}
+
+public:
+	[[nodiscard]] bool canQuit() const { return true; }
+	[[nodiscard]] bool canRaise() const { return true; }
+	[[nodiscard]] bool hasTrackList() const { return false; }
+	[[nodiscard]] QString identity() const { return u"Telegram Desktop"_q; }
+	[[nodiscard]] QString desktopEntry() const { return u"org.telegram.desktop"_q; }
+	[[nodiscard]] QStringList supportedUriSchemes() const { return {}; }
+	[[nodiscard]] QStringList supportedMimeTypes() const { return {}; }
+};
+
+class MprisPlayerAdaptor : public QDBusAbstractAdaptor {
+	Q_OBJECT
+public:
+	explicit MprisPlayerAdaptor(QObject *parent) : QDBusAbstractAdaptor(parent) {}
+
+public Q_SLOTS:
+	void Next() { fireCommand(SystemMediaControls::Command::Next); }
+	void Previous() { fireCommand(SystemMediaControls::Command::Previous); }
+	void Pause() { fireCommand(SystemMediaControls::Command::Pause); }
+	void PlayPause() { fireCommand(SystemMediaControls::Command::PlayPause); }
+	void Stop() { fireCommand(SystemMediaControls::Command::Stop); }
+	void Play() { fireCommand(SystemMediaControls::Command::Play); }
+	void Seek(qlonglong offset) {
+		// offset in us, convert to rough progress delta if we have duration.
+		// For simplicity we fire a generic seek; the manager will handle.
+		// We use a small negative/positive convention or just ignore precise offset here.
+		_fireSeek(0.01 * (offset > 0 ? 1. : -1.)); // rough
+	}
+	void SetPosition(const QDBusObjectPath &trackId, qlonglong position) {
+		Q_UNUSED(trackId);
+		// position usec. Map to 0..1 if we knew duration, otherwise just request update.
+		_fireSeekRequest(position / 1000000.); // very rough, manager will correct
+	}
+	void OpenUri(const QString &) {}
+
+Q_SIGNALS:
+	void Seeked(qlonglong position);
+
+public:
+	[[nodiscard]] QString playbackStatus() const { return MprisStatus(_status); }
+	[[nodiscard]] QString loopStatus() const { return MprisLoopStatus(_loop); }
+	void setLoopStatus(const QString &value) {
+		auto status = SystemMediaControls::LoopStatus::None;
+		if (value == u"Track"_q) status = SystemMediaControls::LoopStatus::Track;
+		else if (value == u"Playlist"_q) status = SystemMediaControls::LoopStatus::Playlist;
+		_fireLoop(status);
+	}
+	[[nodiscard]] double rate() const { return 1.0; }
+	[[nodiscard]] bool shuffle() const { return _shuffle; }
+	void setShuffle(bool value) { _fireShuffle(value); }
+	[[nodiscard]] QVariantMap metadata() const { return _metadata; }
+	[[nodiscard]] double volume() const { return _volume; }
+	void setVolume(double value) { _fireVolume(value); }
+	[[nodiscard]] qlonglong position() const {
+		// Return last known (usec). The manager subscribes to updatePositionRequests
+		// and will push fresh values via setPosition.
+		return qlonglong(_position) * 1000;
+	}
+	[[nodiscard]] double minimumRate() const { return 1.0; }
+	[[nodiscard]] double maximumRate() const { return 1.0; }
+	[[nodiscard]] bool canGoNext() const { return _canNext; }
+	[[nodiscard]] bool canGoPrevious() const { return _canPrev; }
+	[[nodiscard]] bool canPlay() const { return _canPlayPause; }
+	[[nodiscard]] bool canPause() const { return _canPlayPause; }
+	[[nodiscard]] bool canSeek() const { return _canSeek; }
+	[[nodiscard]] bool canControl() const { return true; }
+
+	void setInternalState(
+			SystemMediaControls::PlaybackStatus status,
+			SystemMediaControls::LoopStatus loop,
+			bool shuffle,
+			const QVariantMap &metadata,
+			double volume,
+			int positionMs,
+			bool canNext,
+			bool canPrev,
+			bool canPlayPause,
+			bool canSeek) {
+		const auto changed = (_status != status)
+			|| (_loop != loop)
+			|| (_shuffle != shuffle)
+			|| (_metadata != metadata)
+			|| (_volume != volume)
+			|| (_position != positionMs)
+			|| (_canNext != canNext)
+			|| (_canPrev != canPrev)
+			|| (_canPlayPause != canPlayPause)
+			|| (_canSeek != canSeek);
+		_status = status;
+		_loop = loop;
+		_shuffle = shuffle;
+		_metadata = metadata;
+		_volume = volume;
+		_position = positionMs;
+		_canNext = canNext;
+		_canPrev = canPrev;
+		_canPlayPause = canPlayPause;
+		_canSeek = canSeek;
+		if (changed) {
+			notifyPropertiesChanged();
+		}
+	}
+
+	void setCommandHandler(Fn<void(SystemMediaControls::Command)> handler) { _commandHandler = std::move(handler); }
+	void setSeekHandler(Fn<void(float64)> handler) { _seekHandler = std::move(handler); }
+	void setVolumeHandler(Fn<void(float64)> handler) { _volumeHandler = std::move(handler); }
+	void setUpdatePositionHandler(Fn<void()> handler) { _updatePositionHandler = std::move(handler); }
+
+private:
+	void fireCommand(SystemMediaControls::Command command) {
+		if (_commandHandler) _commandHandler(command);
+	}
+	void _fireSeek(float64 delta) {
+		if (_seekHandler) _seekHandler(delta);
+	}
+	void _fireSeekRequest(float64 progress) {
+		if (_seekHandler) _seekHandler(progress);
+	}
+	void _fireLoop(SystemMediaControls::LoopStatus status) {
+		if (_commandHandler) {
+			switch (status) {
+			case SystemMediaControls::LoopStatus::None: _commandHandler(SystemMediaControls::Command::LoopNone); break;
+			case SystemMediaControls::LoopStatus::Track: _commandHandler(SystemMediaControls::Command::LoopTrack); break;
+			case SystemMediaControls::LoopStatus::Playlist: _commandHandler(SystemMediaControls::Command::LoopPlaylist); break;
+			}
+		}
+	}
+	void _fireShuffle(bool on) {
+		if (_commandHandler) _commandHandler(on ? SystemMediaControls::Command::Shuffle : SystemMediaControls::Command::Shuffle);
+	}
+	void _fireVolume(float64 v) {
+		if (_volumeHandler) _volumeHandler(v);
+	}
+	void _fireUpdatePosition() {
+		if (_updatePositionHandler) _updatePositionHandler();
+	}
+
+	void notifyPropertiesChanged() {
+		QVariantMap changed;
+		changed.insert(u"PlaybackStatus"_q, playbackStatus());
+		changed.insert(u"LoopStatus"_q, loopStatus());
+		changed.insert(u"Shuffle"_q, shuffle());
+		changed.insert(u"Metadata"_q, metadata());
+		changed.insert(u"Volume"_q, volume());
+		changed.insert(u"Position"_q, position());
+		changed.insert(u"CanGoNext"_q, canGoNext());
+		changed.insert(u"CanGoPrevious"_q, canGoPrevious());
+		changed.insert(u"CanPlay"_q, canPlay());
+		changed.insert(u"CanPause"_q, canPause());
+		changed.insert(u"CanSeek"_q, canSeek());
+
+		auto signal = QDBusMessage::createSignal(
+			kMprisPath,
+			u"org.freedesktop.DBus.Properties"_q,
+			u"PropertiesChanged"_q);
+		signal << u"org.mpris.MediaPlayer2.Player"_q;
+		signal << changed;
+		signal << QStringList(); // invalidated
+		QDBusConnection::sessionBus().send(signal);
+	}
+
+	SystemMediaControls::PlaybackStatus _status = SystemMediaControls::PlaybackStatus::Stopped;
+	SystemMediaControls::LoopStatus _loop = SystemMediaControls::LoopStatus::None;
+	bool _shuffle = false;
+	QVariantMap _metadata;
+	double _volume = 1.;
+	int _position = 0;
+	bool _canNext = false;
+	bool _canPrev = false;
+	bool _canPlayPause = false;
+	bool _canSeek = false;
+
+	Fn<void(SystemMediaControls::Command)> _commandHandler;
+	Fn<void(float64)> _seekHandler;
+	Fn<void(float64)> _volumeHandler;
+	Fn<void()> _updatePositionHandler;
+};
+
+} // namespace
