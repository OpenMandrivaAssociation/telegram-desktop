+class Page final : public QWebEnginePage {
+public:
+	using QWebEnginePage::QWebEnginePage;
+
+	bool acceptNavigationRequest(
+			const QUrl &url,
+			NavigationType type,
+			bool isMainFrame) override;
+
+	void setMessageHandler(Fn<void(std::string, bool)> handler) {
+		_messageHandler = std::move(handler);
+	}
+	void setNavigationStartHandler(Fn<bool(std::string, bool)> handler) {
+		_navStartHandler = std::move(handler);
+	}
+	void setNavigationDoneHandler(Fn<void(bool)> handler) {
+		_navDoneHandler = std::move(handler);
+	}
+
+protected:
+	void javaScriptAlert(const QUrl &origin, const QString &msg) override;
+	bool javaScriptConfirm(const QUrl &origin, const QString &msg) override;
+	bool javaScriptPrompt(
+		const QUrl &origin,
+		const QString &msg,
+		const QString &defaultValue,
+		QString *result) override;
+
+private:
+	Fn<void(std::string, bool)> _messageHandler;
+	Fn<bool(std::string, bool)> _navStartHandler;
+	Fn<void(bool)> _navDoneHandler;
+};
+
+bool Page::acceptNavigationRequest(
+		const QUrl &url,
+		NavigationType type,
+		bool isMainFrame) {
+	const auto scheme = url.scheme();
+	if (scheme == kMessageScheme) {
+		if (_messageHandler && url.path().startsWith(kMessagePath)) {
+			auto data = QUrlQuery(url).queryItemValue("data").toStdString();
+			_messageHandler(std::move(data), isMainFrame);
+		}
+		return false;
+	}
+	if (_navStartHandler) {
+		const auto external = (type == NavigationTypeRedirect);
+		if (!_navStartHandler(url.toString().toStdString(), external)) {
+			return false;
+		}
+	}
+	return QWebEnginePage::acceptNavigationRequest(url, type, isMainFrame);
+}
+
+void Page::javaScriptAlert(const QUrl &origin, const QString &msg) {
+	QWebEnginePage::javaScriptAlert(origin, msg);
+}
+
+bool Page::javaScriptConfirm(const QUrl &origin, const QString &msg) {
+	return QWebEnginePage::javaScriptConfirm(origin, msg);
+}
+
+bool Page::javaScriptPrompt(
+		const QUrl &origin,
+		const QString &msg,
+		const QString &defaultValue,
+		QString *result) {
+	return QWebEnginePage::javaScriptPrompt(origin, msg, defaultValue, result);
+}
